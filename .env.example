# Google Sheets Configuration
VITE_GOOGLE_SHEETS_ID=seu-google-sheet-id-aqui
VITE_GOOGLE_API_KEY=sua-chave-api-do-google-aqui

# WhatsApp Business API
VITE_WHATSAPP_API_KEY=sua-chave-whatsapp-aqui
VITE_WHATSAPP_PHONE_ID=seu-phone-id-aqui
VITE_WHATSAPP_BUSINESS_ACCOUNT_ID=seu-business-account-id

# Environment
VITE_ENV=development
VITE_API_URL=http://localhost:3000/api

# Sincronização
VITE_SYNC_INTERVAL=300000
VITE_SYNC_RETRIES=3
